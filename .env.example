# ─────────────────────────────────────────────────────────────────────────────
# LEAN Data Platform - Environment Variables
# cp .env.example .env  then fill in real values. Never commit .env.
# ─────────────────────────────────────────────────────────────────────────────

# ── Databento ─────────────────────────────────────────────────────────────────
DATABENTO_API_KEY=db-your-key-here

# ── Financial Modeling Prep ───────────────────────────────────────────────────
FMP_API_KEY=your-fmp-key-here

# ── PostgreSQL (TARS @ 192.168.17.4) ─────────────────────────────────────────
PGUSER=eqty
PGPASS=1234
PGHOST=192.168.17.4
PGPORT=5432
PGDB=FinancialData

# ── LEAN / QuantConnect ───────────────────────────────────────────────────────
# Controls local vs cloud data routing in QC algorithms.
# Set to "local" on your dev machine; leave unset on QC cloud (defaults to cloud).
QC_RUN_ENV=local

# ── Dagster ───────────────────────────────────────────────────────────────────
DAGSTER_HOME=/app/dagster_home

# Dagster GraphQL endpoint - used by algorithms to fire ingestion jobs.
# On HAL-107 (algorithms + Dagster on the same machine): use localhost.
# From a remote machine (laptop, SSH): use HAL-107's LAN IP.
DAGSTER_HOST=localhost
DAGSTER_PORT=3000

# ── LEAN data root ────────────────────────────────────────────────────────────
# HOST-SIDE absolute path to the LEAN data directory (~/Projects/Algo/data).
# Used as the bind-mount source in docker-compose.yml AND by CoverageChecker
# to verify LEAN ZIPs exist on disk before a backtest.
#
# IMPORTANT: Docker Compose does NOT expand ~ - use the full absolute path.
# Inside the container the mount target is always /app/data (do not change).
LEAN_DATA_ROOT=/home/your-username/Projects/Algo/data
