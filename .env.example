# ─────────────────────────────────────────────────────────────────────────────
# LEAN Data Platform — Environment Variables
# cp .env.example .env  then fill in real values. Never commit .env.
# ─────────────────────────────────────────────────────────────────────────────

# ── Databento ─────────────────────────────────────────────────────────────────
DATABENTO_API_KEY=db-your-key-here

# ── Financial Modeling Prep ───────────────────────────────────────────────────
FMP_API_KEY=your-fmp-key-here

# ── PostgreSQL (TARS @ 192.168.17.4) ─────────────────────────────────────────
PGUSER=eqty
PGPASS=1234
PGHOST=192.168.17.4
PGPORT=5432
PGDB=FinancialData

# ── LEAN / QuantConnect ───────────────────────────────────────────────────────
# Controls local vs cloud data routing in QC algorithms.
# Set to "local" on your dev machine; leave unset on QC cloud (defaults to cloud).
QC_RUN_ENV=local

# ── Dagster ───────────────────────────────────────────────────────────────────
DAGSTER_HOME=/app/dagster_home
